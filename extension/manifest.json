{
  "manifest_version": 3,
  "name": "Critique",
  "version": "0.1.0",
  "description": "AI code review overlays for GitHub PRs.",
  "action": {
    "default_title": "Critique",
    "default_popup": "popup.html"
  },
  "background": {
    "service_worker": "background.js"
  },
  "permissions": [
    "storage",
    "tabs"
  ],
  "host_permissions": [
    "https://github.com/*",
    "https://*.github.com/*",
    "http://localhost:*/*",
    "http://127.0.0.1:*/*",
    "https://*/*",
    "http://*/*"
  ],
  "content_scripts": [
    {
      "matches": [
        "https://github.com/*",
        "https://*.github.com/*"
      ],
      "js": ["contentScript.js"],
      "run_at": "document_idle"
    }
  ],
  "icons": {
    "16": "assets/icon.svg",
    "48": "assets/icon.svg",
    "128": "assets/icon.svg"
  }
}