{
  "manifest_version": 3,
  "name": "Critique",
  "version": "0.1.0",
  "description": "AI code review overlays for GitHub PRs.",
  "action": {
    "default_title": "Critique",
    "default_popup": "popup/popup.html"
  },
  "background": {
    "service_worker": "background/service-worker.js"
  },
  "permissions": [
    "storage",
    "tabs"
  ],
  "host_permissions": [
    "https://github.com/*",
    "https://*.github.com/*",
    "http://localhost:*/*",
    "http://127.0.0.1:*/*",
    "https://*/*",
    "http://*/*"
  ],
  "web_accessible_resources": [
    {
      "resources": ["sidebar/sidebar.html"],
      "matches": [
        "https://github.com/*",
        "https://*.github.com/*"
      ]
    }
  ],
  "content_scripts": [
    {
      "matches": [
        "https://github.com/*",
        "https://*.github.com/*"
      ],
      "js": [
        "content/github.js",
        "content/pr-review.js",
        "sidebar/sidebar.js"
      ],
      "css": ["content/pr-review.css"],
      "run_at": "document_idle"
    }
  ],
  "icons": {
    "16": "icons/logo.svg",
    "48": "icons/logo.svg",
    "128": "icons/logo.svg"
  }
}
